<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Dashboard</title>
  <style>
    :root {
      --bg: #0f1410;
      --panel: #151b16;
      --text: #e8f0d9;
      --muted: #9ca18d;
      --accent: #9cff5c;
      --border: #2f362a;
    }

    * {
      box-sizing: border-box;
    }

    body {
      margin: 0;
      min-height: 100vh;
      font-family: Inter, system-ui, sans-serif;
      background: radial-gradient(circle at top left, rgba(156, 255, 92, 0.14), transparent 25%), #090d08;
      color: var(--text);
    }

    header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 1rem 1.5rem;
      background: rgba(13, 18, 12, 0.95);
      border-bottom: 1px solid rgba(156, 255, 92, 0.12);
      position: sticky;
      top: 0;
      z-index: 10;
    }

    .header-title {
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
    }

    .header-title span {
      color: var(--muted);
      font-size: 0.95rem;
    }

    .header-title h1 {
      margin: 0;
      font-size: 1.25rem;
      color: var(--accent);
    }

    .logout-btn {
      border: none;
      border-radius: 999px;
      padding: 0.85rem 1.2rem;
      background: var(--accent);
      color: #081205;
      font-weight: 700;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .logout-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 0 0 6px rgba(156, 255, 92, 0.14);
    }

    .header-actions {
      display: flex;
      gap: 0.75rem;
      align-items: center;
      flex-wrap: wrap;
    }

    .action-btn {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      border: none;
      border-radius: 999px;
      padding: 0.85rem 1.2rem;
      background: rgba(156, 255, 92, 0.12);
      color: var(--text);
      font-weight: 700;
      text-decoration: none;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .action-btn:hover {
      transform: translateY(-1px);
      box-shadow: 0 0 0 4px rgba(156, 255, 92, 0.12);
    }

    .delete-btn {
      background: rgba(255, 59, 48, 0.12);
      color: #ff3b30;
      border: 1px solid rgba(255, 59, 48, 0.3);
      border-radius: 4px;
      padding: 0.5rem 0.75rem;
      font-size: 0.85rem;
      cursor: pointer;
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

    .delete-btn:hover {
      background: rgba(255, 59, 48, 0.2);
      transform: translateY(-1px);
      box-shadow: 0 0 0 4px rgba(255, 59, 48, 0.1);
    }

    .project-item {
      display: flex;
      justify-content: space-between;
      align-items: center;
    }

    .project-info {
      flex: 1;
    }

    main {
      max-width: 1180px;
      margin: 0 auto;
      padding: 1.5rem;
      display: grid;
      gap: 1.5rem;
    }

    .grid {
      display: grid;
      grid-template-columns: 1.5fr 1fr;
      gap: 1.5rem;
    }

    .card {
      background: var(--panel);
      border: 1px solid var(--border);
      border-radius: 22px;
      padding: 1.5rem;
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.18);
    }

    .card h2 {
      margin: 0 0 1rem 0;
      font-size: 1.1rem;
      color: var(--accent);
      letter-spacing: 0.02em;
    }

    .label-row {
      display: flex;
      justify-content: space-between;
      align-items: center;
      gap: 1rem;
      flex-wrap: wrap;
      color: var(--muted);
      margin-bottom: 0.75rem;
    }

    .project-list {
      max-height: 320px;
      overflow-y: auto;
      padding: 0.5rem;
      border: 1px solid rgba(156, 255, 92, 0.16);
      border-radius: 18px;
      background: rgba(156, 255, 92, 0.04);
    }

    .project-item {
      padding: 0.95rem 1rem;
      margin-bottom: 0.75rem;
      border-radius: 16px;
      background: rgba(156, 255, 92, 0.08);
      border: 1px solid rgba(156, 255, 92, 0.12);
    }

    .project-item:last-child {
      margin-bottom: 0;
    }

    .project-item h3 {
      margin: 0 0 0.4rem 0;
      font-size: 1rem;
      color: var(--text);
    }

    .project-item p {
      margin: 0;
      font-size: 0.92rem;
      color: var(--muted);
    }

    .skills-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(120px, 1fr));
      gap: 0.9rem;
    }

    .skill-pill {
      padding: 0.8rem 1rem;
      border-radius: 999px;
      background: rgba(156, 255, 92, 0.12);
      border: 1px solid rgba(156, 255, 92, 0.18);
      color: var(--text);
      text-align: center;
      font-size: 0.95rem;
    }

    .footer-note {
      color: var(--muted);
      margin: 0;
      padding: 1rem 0;
    }

    @media (max-width: 860px) {
      .grid {
        grid-template-columns: 1fr;
      }

      header {
        flex-direction: column;
        align-items: flex-start;
        gap: 10px;
      }
    }

    @media (max-width: 480px) {
     .action-btn {
      font-size: 0.8rem;
   font-weight: 500;

    padding: 0.55rem 0.8rem;
  
    transition: transform 0.2s ease, box-shadow 0.2s ease;
}

  .logout-btn {
     
      padding: 0.55rem 0.8rem;
     
      transition: transform 0.2s ease, box-shadow 0.2s ease;
    }
    }
  </style>
</head>
<body>
  <header>
    <div class="header-title">
      <span>Dashboard</span>
      <h1><%= typeof username !== 'undefined' ? username : 'Yash Choudhary' %></h1>
    </div>
    <div class="header-actions">
      <a href="/api/projects/add" class="action-btn">Add Project</a>
      <a href="/api/skills/add" class="action-btn">Add Skill</a>
      <form action="/api/auth/logout" method="post">
        <button type="submit" class="logout-btn">Logout</button>
      </form>
    </div>
  </header>

  <main>
    <div class="grid">
      <section class="card">
        <div class="label-row">
          <h2>Projects</h2>
          <span>Total: <%= projects && projects.length ? projects.length : 0 %></span>
        </div>
        <div class="project-list">
          <% if (projects && projects.length) { %>
            <% projects.slice(0, 10).forEach(function(project) { %>
              <div class="project-item">
                <div class="project-info">
                  <h3><%= project.title %></h3>
                  <p><%= project.techStack %></p>
                </div>
                <form action="/api/projects/delete/<%= project._id %>" method="post" style="margin: 0;">
                  <button type="submit" class="delete-btn" onclick="return confirm('Are you sure you want to delete this project?');">Delete</button>
                </form>
              </div>
            <% }) %>
          <% } else { %>
            <p class="footer-note">No projects available.</p>
          <% } %>
        </div>
      </section>

      <section class="card">
        <div class="label-row">
          <h2>Skills</h2>
          <span>Total: <%= skills && skills.length ? skills.length : 0 %></span>
        </div>
        <div class="skills-grid">
          <% if (skills && skills.length) { %>
            <% skills.forEach(function(skill) { %>
              <div class="skill-pill"><%= skill %></div>
            <% }) %>
          <% } else { %>
            <p class="footer-note">No skills added yet.</p>
          <% } %>
        </div>
      </section>
    </div>
  </main>
</body>
</html>
